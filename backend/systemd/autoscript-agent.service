[Unit]
Description=Autoscript Panel Agent (FastAPI, TLS)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=/etc/autoscript/agent.env
WorkingDirectory=/opt/autoscript/backend/agent
ExecStart=/opt/autoscript/backend/.venv/bin/uvicorn main:app \
    --host 0.0.0.0 --port ${PANEL_PORT} \
    --ssl-certfile ${CERT_FULLCHAIN} --ssl-keyfile ${CERT_KEY} \
    --proxy-headers --forwarded-allow-ips=*
Restart=on-failure
RestartSec=3
# Hardening — the agent still needs root for tc/useradd/systemctl.
User=root
NoNewPrivileges=false
ProtectSystem=full
ProtectHome=true
PrivateTmp=true
ReadWritePaths=/etc/autoscript /opt/autoscript /usr/local/etc/xray /var/log /tmp
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
