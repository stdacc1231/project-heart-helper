[Unit]
Description=Autoscript SSH-over-WebSocket bridge
After=network-online.target sshd.service
Wants=network-online.target

[Service]
Type=simple
ExecStart=/opt/autoscript/backend/.venv/bin/python /opt/autoscript/backend/agent/ssh_ws.py
Restart=on-failure
RestartSec=3
User=root

[Install]
WantedBy=multi-user.target
